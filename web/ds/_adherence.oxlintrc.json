{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/forms/**",
              "components/review/**",
              "components/status/**",
              "ui_kits/editor/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:count|mark)$/]",
        "message": "<Badge> variant must be one of 'count' | 'mark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|active|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, active, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|small)$/]",
        "message": "<Button> size must be one of 'default' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|mini)$/]",
        "message": "<IconButton> size must be one of 'default' | 'mini'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|time|variant|typing|children|key|ref|className|style|children)$/]",
        "message": "<MessageBubble> doesn't accept that prop. Declared props: author, time, variant, typing, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBubble'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:human|agent|error)$/]",
        "message": "<MessageBubble> variant must be one of 'human' | 'agent' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|icon|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: state, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|running|error|accent)$/]",
        "message": "<Pill> state must be one of 'idle' | 'running' | 'error' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|disabled|width|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, value, onChange, disabled, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:muted|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<SkillChip> doesn't accept that prop. Declared props: muted, onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SuggestionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|status|state|children|key|ref|className|style|children)$/]",
        "message": "<SuggestionCard> doesn't accept that prop. Declared props: label, status, state, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SuggestionCard'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:open|accepted|rejected)$/]",
        "message": "<SuggestionCard> state must be one of 'open' | 'accepted' | 'rejected'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThreadCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|meta|active|resolved|key|ref|className|style|children)$/]",
        "message": "<ThreadCard> doesn't accept that prop. Declared props: index, title, meta, active, resolved."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
