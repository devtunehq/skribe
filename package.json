{
  "name": "skribe-editor",
  "version": "0.4.2",
  "description": "Local-first Markdown writing and review workbench with AI chat, comments, and reviewable diffs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/devtunehq/skribe.git"
  },
  "bugs": {
    "url": "https://github.com/devtunehq/skribe/issues"
  },
  "homepage": "https://github.com/devtunehq/skribe#readme",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "skribe": "bin/skribe.mjs"
  },
  "files": [
    "bin/",
    "server/",
    "dist/",
    "docs/screenshots/",
    "README.md",
    "LICENSE",
    "PRODUCT.md"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "prepack": "npm run build",
    "serve": "node server/index.mjs",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test test/*.test.mjs",
    "test:e2e": "npm run build && node scripts/run-e2e.mjs",
    "typecheck": "tsc -b",
    "doctor": "react-doctor",
    "doctor:diff": "react-doctor --verbose --diff main"
  },
  "devDependencies": {
    "@pierre/diffs": "^1.2.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-doctor": "^0.4.2",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
